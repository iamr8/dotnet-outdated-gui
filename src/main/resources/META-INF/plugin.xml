<idea-plugin>
    <id>com.github.iamr8.dotnetoutdated</id>
    <name>dotnet outdated GUI</name>
    <vendor url="https://github.com/iamr8" email="arash.shabbeh@gmail.com">iamr8</vendor>

    <description><![CDATA[
        A GUI for the <a href="https://github.com/dotnet-outdated/dotnet-outdated">dotnet-outdated</a>
        CLI, built for <b>real-world .NET solutions</b>:
        <ul>
          <li><b>Central Package Management</b> — reads and updates versions in
              <code>Directory.Packages.props</code>, not the individual <code>.csproj</code> files.</li>
          <li><b>NuGet version ranges &amp; floating versions</b> — interval notation like
              <code>[1.0.0,2.0.0)</code>, <code>(,3.0.0]</code>, <code>[1.2.3]</code> and floating
              <code>3.*</code> are resolved to the concrete current version instead of choking on the
              bracket notation.</li>
        </ul>
        Lists NuGet packages in the open solution's projects with their current version, and on
        demand runs <code>dotnet outdated</code> to show available updates in a Rider NuGet-style
        list — the new version colored by <b>NuGet / Semantic Versioning</b> severity: green = patch
        (backwards-compatible fixes), yellow = minor (backwards-compatible features), red = major or
        pre-release (possible breaking changes). Check the packages you want and upgrade them in place.
        <br/><br/>
        Source &amp; issues: <a href="https://github.com/iamr8/dotnet-outdated-gui">github.com/iamr8/dotnet-outdated-gui</a>
    ]]></description>

    <change-notes><![CDATA[
        See the <a href="https://github.com/iamr8/dotnet-outdated-gui/blob/main/CHANGELOG.md">CHANGELOG</a>
        for release notes.
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <errorHandler implementation="com.github.iamr8.dotnetoutdated.PluginErrorReportSubmitter"/>
        <editorNotificationProvider implementation="com.github.iamr8.dotnetoutdated.ui.DotnetProjectNotificationProvider"/>

        <!--
          Marketplace Plugin Advertiser: Rider's dotnet dependency collector matches a project's
          NuGet references against these coordinates and suggests installing this plugin (once
          published). Covers ubiquitous packages so most real .NET solutions trigger it.
        -->
        <dependencySupport kind="dotnet" coordinate="Newtonsoft.Json" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Microsoft.Extensions.DependencyInjection" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Microsoft.Extensions.Hosting" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Microsoft.EntityFrameworkCore" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Microsoft.AspNetCore.App" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Serilog" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Swashbuckle.AspNetCore" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="AutoMapper" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="FluentValidation" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="MediatR" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Dapper" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Polly" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="xunit" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="NUnit" displayName="NuGet"/>
        <dependencySupport kind="dotnet" coordinate="Moq" displayName="NuGet"/>
        <projectConfigurable
            parentId="tools"
            id="nuget.extended"
            displayName="dotnet outdated GUI"
            instance="com.github.iamr8.dotnetoutdated.settings.OutdatedConfigurable"/>
        <toolWindow
            id="dotnet outdated GUI"
            anchor="right"
            icon="/icons/dotnetOutdated.svg"
            factoryClass="com.github.iamr8.dotnetoutdated.ui.OutdatedToolWindowFactory"/>
    </extensions>
</idea-plugin>
